# Base URL of the backend API (apps/server). Exposed to the browser, so it
# must be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Minimum level for the browser client logger (debug | info | warn | error).
# Prefixed with NEXT_PUBLIC_ so it is exposed to the browser.
NEXT_PUBLIC_LOG_LEVEL="info"
