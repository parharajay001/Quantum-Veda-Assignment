PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/taskdb?schema=public"
# Minimum log level for the winston logger (debug | info | warn | error).
LOG_LEVEL="debug"
# Secret used to sign/verify JWTs. Use a strong, random value in production.
JWT_SECRET="dev-only-insecure-jwt-secret"
# JWT lifetime (vercel/ms format, e.g. 7d, 12h, 3600).
JWT_EXPIRES_IN="7d"
